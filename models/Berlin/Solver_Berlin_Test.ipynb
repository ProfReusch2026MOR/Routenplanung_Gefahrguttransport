    "    \"nodes_raw\":                     len(berlin_graph_accidents['nodes']),\n",
    "    \"edges_raw\":                     len(berlin_graph_accidents['edges']),\n",
    "\n",
    "    # Nach Kontraktion \n",
    "    \"nodes_after_contraction\":       len(N),\n",
    "    \"edges_after_contraction\":       len(E),\n",
    "\n",
    "    # Nach Spatial Bounding pro Lieferung\n",
    "    \"solver_variables_f\":            len(valid_le_pairs),\n",
    "    \"solver_edges_per_delivery\":     {l: len(edges_per_l[l]) for l in L},\n",
    "    \"solver_nodes_per_delivery\":     {l: len(nodes_per_l[l]) for l in L},\n",
    "    \"solver_total_unique_edges\":     len(set(e for l in L for e in edges_per_l[l])),\n",
