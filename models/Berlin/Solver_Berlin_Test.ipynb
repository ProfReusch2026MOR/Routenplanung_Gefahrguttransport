    "# ============================================================\n",
    "#  KARTEN-VISUALISIERUNG (Folium)\n",
    "#  – Eine Karte pro Lieferung\n",
    "#  – Optionale Layer: Naturschutz, Population, Accidents\n",
    "# ============================================================\n",
    "import folium\n",
    "from folium.plugins import MiniMap, HeatMap\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 1. HILFSDATEN AUFBAUEN\n",
    "# ----------------------------------------------------------------\n",
    "\n",
    "# Knotendaten: node -> (lat, lon)\n",
    "# berlin_graph_accidents['nodes'] hat Spalten: node, lat, lon\n",
    "df_nodes_acc = berlin_graph_accidents['nodes']\n",
    "node_coords  = df_nodes_acc.set_index('node')[['lat', 'lon']].apply(tuple, axis=1).to_dict()\n",
    "\n",
    "# Kantendaten: (u, v) -> [(lat_u, lon_u), (lat_v, lon_v)]\n",
    "# berlin_graph_accidents['edges'] hat Spalten: u, v, score, weighted_score, ...\n",
    "df_edges_acc = berlin_graph_accidents['edges']\n",
    "arc_coords   = {}\n",
    "\n",
    "for _, row in df_edges_acc.iterrows():\n",
    "    u, v = int(row['u']), int(row['v'])\n",
    "    coord_u = node_coords.get(u)\n",
    "    coord_v = node_coords.get(v)\n",
    "    if coord_u and coord_v:\n",
    "        arc_coords[(u, v)] = [coord_u, coord_v]\n",
    "\n",
    "print(f\"node_coords: {len(node_coords):,} Knoten\")\n",
    "print(f\"arc_coords:  {len(arc_coords):,} Kanten\")\n",
    "\n",
    "# Risikowerte direkt aus den Accident-Edges holen\n",
    "# score = Unfallscore pro Kante (bereits in den Daten vorhanden)\n",
    "acc_raw = {\n",
    "    (int(row['u']), int(row['v'])): row['score']\n",
    "    for _, row in df_edges_acc.iterrows()\n",
    "}\n",
    "\n",
    "# Normalisieren auf [0, 1]\n",
    "acc_values  = list(acc_raw.values())\n",
    "acc_min     = min(acc_values)\n",
    "acc_max     = max(acc_values)   # = 1.746 laut deinem Output\n",
    "acc_range   = acc_max - acc_min if acc_max > acc_min else 1\n",
    "\n",
    "acc_norm = {e: (v - acc_min) / acc_range for e, v in acc_raw.items()}\n",
    "\n",
    "print(f\"acc_norm: min={min(acc_norm.values()):.3f}, max={max(acc_norm.values()):.3f}\")\n",
    "print(f\"Kanten mit acc > 0: {sum(1 for v in acc_norm.values() if v > 0):,}\")\n",
    "\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 2. HEATMAP-DATEN VORBEREITEN\n",
    "# ----------------------------------------------------------------\n",
    "\n",
    "# FIX 2 + 3: Statt PolyLines mit threshold → HeatMap über alle Kanten\n",
    "# Kein Schwellwert, kein Bounding-Box-Filter → ganz Berlin wird eingefärbt\n",
    "# Mittelpunkt jeder Kante als Heatmap-Punkt mit norm_val als Gewicht\n",
    "\n",
    "\n",
    "def build_heatmap_data(norm_dict):\n",
    "    \"\"\"Wandelt ein (u,v)->norm_val Dict in HeatMap-Punkte [lat, lon, weight] um.\"\"\"\n",
    "    heat_data = []\n",
    "\n",
    "    for (u, v), norm_val in norm_dict.items():\n",
    "        \n",
    "        coords = None\n",
    "\n",
    "        # ✅ 1. Versuch: Koordinaten aus kontrahiertem Graph holen\n",
    "        if G_contract.has_edge(u, v):\n",
    "            coords = G_contract[u][v].get('coords')\n",
    "\n",
    "        # ✅ 2. Fallback: direkte Linie zwischen Knoten\n",
    "        if not coords:\n",
    "            coord_u = node_coords.get(u)\n",
    "            coord_v = node_coords.get(v)\n",
    "\n",
    "            if coord_u and coord_v:\n",
    "                coords = [coord_u, coord_v]\n",
    "\n",
    "        # ✅ 3. Wärme-Punkt berechnen\n",
    "        if coords and norm_val > 0.0:\n",
    "            mid_lat = (coords[0][0] + coords[-1][0]) / 2\n",
    "            mid_lon = (coords[0][1] + coords[-1][1]) / 2\n",
    "\n",
    "            heat_data.append([mid_lat, mid_lon, float(norm_val)])\n",
    "\n",
    "    return heat_data\n",
    "\n",
    "\n",
    "print(\"Berechne HeatMap-Daten...\")\n",
    "pop_heat = build_heatmap_data(pop_norm)\n",
    "acc_heat = build_heatmap_data(acc_norm)\n",
    "nat_heat = build_heatmap_data(nat_norm)\n",
    "print(f\"  Population:   {len(pop_heat):,} Punkte\")\n",
    "print(f\"  Unfallrate:   {len(acc_heat):,} Punkte\")\n",
    "print(f\"  Naturschutz:  {len(nat_heat):,} Punkte\")\n",
    "\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 3. FARB-HELFER\n",
    "# ----------------------------------------------------------------\n",
    "\n",
    "def risk_to_color(value):\n",
    "    \"\"\"Wert [0,1] → Hex-Farbe grün (#00ff00) bis rot (#ff0000)\"\"\"\n",
    "    r = int(255 * value)\n",
    "    g = int(255 * (1 - value))\n",
    "    return f\"#{r:02x}{g:02x}00\"\n",
    "\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 4. KARTE PRO LIEFERUNG ERZEUGEN\n",
    "# ----------------------------------------------------------------\n",
    "\n",
    "CENTER = (52.5200, 13.4050)\n",
    "\n",
    "ROUTE_COLORS = [\n",
    "    \"#E63946\",  # rot\n",
    "    \"#2196F3\",  # blau\n",
    "    \"#4CAF50\",  # grün\n",
    "    \"#FF9800\",  # orange\n",
    "    \"#9C27B0\",  # lila\n",
    "    \"#00BCD4\",  # cyan\n",
    "]\n",
    "\n",
    "\n",
    "def build_map_for_lieferung(l, geordnete_route, zugewiesenes_v):\n",
    "    \"\"\"\n",
    "    Erzeugt eine Folium-Karte für eine einzelne Lieferung.\n",
    "    geordnete_route: Liste von (u, v)-Tupeln in Reihenfolge\n",
    "    \"\"\"\n",
    "\n",
    "    m = folium.Map(location=CENTER, zoom_start=12, tiles=\"CartoDB positron\")\n",
    "    MiniMap(toggle_display=True).add_to(m)\n",
    "\n",
    "    route_color = ROUTE_COLORS[l % len(ROUTE_COLORS)]\n",
    "\n",
    "    # ----------------------------------------------------------\n",
    "    # LAYER 1: Populationsdichte (HeatMap → ganz Berlin, kein Filter)\n",
    "    # ----------------------------------------------------------\n",
    "    pop_layer = folium.FeatureGroup(name=\"🏙️ Populationsdichte\", show=False)\n",
    "    HeatMap(\n",
    "        pop_heat,\n",
    "        name=\"Populationsdichte\",\n",
    "        min_opacity=0.2,\n",
    "        radius=8,\n",
    "        blur=6,\n",
    "        max_zoom=15,\n",
    "        gradient={0.0: \"green\", 0.5: \"yellow\", 1.0: \"red\"}\n",
    "    ).add_to(pop_layer)\n",
    "    pop_layer.add_to(m)\n",
    "\n",
    "    # ----------------------------------------------------------\n",
    "    # LAYER 2: Unfallrate (HeatMap → ganz Berlin, kein Filter)\n",
    "    # ----------------------------------------------------------\n",
    "    acc_layer = folium.FeatureGroup(name=\"⚠️ Unfallrate\", show=False)\n",
    "    HeatMap(\n",
    "        acc_heat,\n",
    "        name=\"Unfallrate\",\n",
    "        min_opacity=0.2,\n",
    "        radius=8,\n",
    "        blur=6,\n",
    "        max_zoom=15,\n",
    "        gradient={0.0: \"green\", 0.5: \"yellow\", 1.0: \"red\"}\n",
    "    ).add_to(acc_layer)\n",
    "    acc_layer.add_to(m)\n",
    "\n",
    "    # ----------------------------------------------------------\n",
    "    # LAYER 3: Naturschutznähe (HeatMap → ganz Berlin, kein Filter)\n",
    "    # ----------------------------------------------------------\n",
    "    nat_layer = folium.FeatureGroup(name=\"🌿 Naturschutznähe\", show=False)\n",
    "    HeatMap(\n",
    "        nat_heat,\n",
    "        name=\"Naturschutznähe\",\n",
    "        min_opacity=0.2,\n",
    "        radius=8,\n",
    "        blur=6,\n",
    "        max_zoom=15,\n",
    "        gradient={0.0: \"green\", 0.5: \"yellow\", 1.0: \"red\"}\n",
    "    ).add_to(nat_layer)\n",
    "    nat_layer.add_to(m)\n",
    "\n",
    "    # ----------------------------------------------------------\n",
    "    # LAYER 4: Berechnete Route (PolyLine – FIX 1: arc_coords komplett)\n",
    "    # ----------------------------------------------------------\n",
    "    route_layer = folium.FeatureGroup(name=f\"🚛 Route Lieferung {l}\", show=True)\n",
    "\n",
    "    fehlende_kanten = 0\n",
    "    for (u, v) in geordnete_route:\n",
    "        coords = None\n",
    "\n",
    "        # ✅ IMMER aus G_contract holen\n",
    "        if G_contract.has_edge(u, v):\n",
    "            coords = G_contract[u][v].get(\"coords\")\n",
    "\n",
    "        # ✅ Fallback (sollte jetzt selten passieren)\n",
    "        if not coords:\n",
    "            coord_u = node_coords.get(u)\n",
    "            coord_v = node_coords.get(v)\n",
    "            if coord_u and coord_v:\n",
    "                coords = [coord_u, coord_v]\n",
    "\n",
    "        if coords:\n",
    "            risk_val = Risk.get(((u, v), Class[l]), 0)\n",
    "            folium.PolyLine(\n",
    "                locations=coords,\n",
    "                color=route_color,\n",
    "                weight=5,\n",
    "                opacity=0.9,\n",
    "                tooltip=(\n",
    "                    f\"Kante {u} → {v}<br>\"\n",
    "                    f\"Distanz: {Dist.get((u, v), 0):.3f} km<br>\"\n",
    "                    f\"Risiko:  {risk_val:.4f}<br>\"\n",
    "                    f\"Klasse:  {Class[l]}\"\n",
    "                )\n",
    "            ).add_to(route_layer)\n",
    "        else:\n",
    "            fehlende_kanten += 1\n",
    "\n",
    "    if fehlende_kanten > 0:\n",
    "        print(f\"  ⚠️  Lieferung {l}: {fehlende_kanten} Kanten ohne Koordinaten (Route evtl. lückenhaft)\")\n",
    "\n",
    "    route_layer.add_to(m)\n",
    "\n",
    "    # ----------------------------------------------------------\n",
    "    # MARKER: Depot und Ziel\n",
    "    # ----------------------------------------------------------\n",
    "    depot_coords = node_coords.get(O_dep[l])\n",
    "    ziel_coords  = node_coords.get(D_dep[l])\n",
    "\n",
    "    if depot_coords:\n",
    "        folium.Marker(\n",
    "            location=depot_coords,\n",
    "            popup=folium.Popup(f\"<b>Depot</b><br>Knoten: {O_dep[l]}\", max_width=200),\n",
    "            icon=folium.Icon(color=\"blue\", icon=\"home\", prefix=\"fa\")\n",
    "        ).add_to(m)\n",
    "\n",
    "    if ziel_coords:\n",
    "        kunde_name = customer_to_node.get(l, {}).get(\"customer_name\", f\"Kunde {l}\")\n",
    "        folium.Marker(\n",
    "            location=ziel_coords,\n",
    "            popup=folium.Popup(\n",
    "                f\"<b>{kunde_name}</b><br>\"\n",
    "                f\"Lieferung: {l}<br>\"\n",
    "                f\"Klasse: {Class[l]}<br>\"\n",
    "                f\"Menge: {Dem[l]} kg<br>\"\n",
    "                f\"Fahrzeug: {zugewiesenes_v}\",\n",
    "                max_width=250\n",
    "            ),\n",
    "            icon=folium.Icon(color=\"red\", icon=\"truck\", prefix=\"fa\")\n",
    "        ).add_to(m)\n",
    "\n",
    "    folium.LayerControl(collapsed=False).add_to(m)\n",
    "\n",
    "    return m\n",
    "\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 5. KARTEN ERZEUGEN UND SPEICHERN\n",
    "# ----------------------------------------------------------------\n",
    "\n",
    "for entry in summary_table_data:\n",
    "    l              = entry['Lieferung']\n",
    "    zugewiesenes_v = entry['Fahrzeug']\n",
    "    route          = entry.get('geordnete_route', [])\n",
    "\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"  Karte für Lieferung {l} | Fahrzeug: {zugewiesenes_v}\")\n",
    "    print(f\"  Route: {len(route)} Kanten\")\n",
    "    print(f\"{'='*60}\")\n",
    "\n",
    "    karte = build_map_for_lieferung(l, route, zugewiesenes_v)\n",
    "\n",
    "    dateiname = f\"route_lieferung_{l}.html\"\n",
    "    karte.save(dateiname)\n",
    "    print(f\"→ Gespeichert als: {dateiname}\")"
   ]
  }
 ],
