    "        \"vehicles_used\":           list(set(r['Fahrzeug']   for r in summary_table_data)),\n",
    "    }\n",
    "}\n",
    "\n",
    "summary_path = os.path.join(OUTPUT_DIR, f\"solver_summary_{timestamp}.json\")\n",
