    "        if route:\n",
    "            node_ids  = [route[0][0]] + [e[1] for e in route]\n",
    "            arc_ids   = [arc_id_lookup.get(e, -1) for e in route]\n",
    "        else:\n",
    "            node_ids  = []\n",
    "            arc_ids   = []\n",
    "\n",
    "        writer.writerow({\n",
    "            \"delivery_id\":        l,\n",
    "            \"origin_node\":        O_dep[l],\n",
    "            \"destination_node\":   D_dep[l],\n",
    "            \"vehicle_id\":         row['Fahrzeug'],\n",
    "            \"hazard_class\":       Class[l],\n",
    "            \"path_node_ids\":      \";\".join(str(n) for n in node_ids),\n",
    "            \"path_arc_ids\":       \";\".join(str(a) for a in arc_ids),\n",
    "            \"path_length_km\":     round(sum(Dist.get(e, 0) for e in route), 4),\n",
    "            \"path_risk\":          round(row['Risiko'], 4),\n",
    "            \"variable_cost\":      round(row['VarKosten'], 4),\n",
    "            \"fixed_cost\":         round(row['Fixkosten'], 4),\n",
    "            \"total_cost\":         round(row['VarKosten'] + row['Fixkosten'], 4),\n",
    "            \"num_edges\":          len(route),\n",
    "            \"feasible\":           True,\n",
    "            \"solver_status\":      pl.LpStatus[model.status],\n",
    "        })\n",
    "\n",
    "print(f\"solver_selected_paths.csv  => {paths_path}\")\n",
    "\n",
    "\n",
    "# ================================================================\n",
    "# DATEI 3: solver_edges_used.csv\n",
    "# ================================================================\n",
    "edges_path = os.path.join(OUTPUT_DIR, f\"solver_edges_used_{timestamp}.csv\")\n",
    "\n",
    "with open(edges_path, \"w\", newline=\"\", encoding=\"utf-8\") as f_out:\n",
    "    writer = csv.DictWriter(f_out, fieldnames=[\n",
    "        \"delivery_id\", \"step\", \"arc_id\",\n",
    "        \"u\", \"v\",\n",
    "        \"length_km\", \"risk\", \"variable_cost\",\n",
    "        \"is_tunnel_edge\",\n",
    "        \"lat_u\", \"lon_u\", \"lat_v\", \"lon_v\"\n",
    "    ])\n",
    "    writer.writeheader()\n",
    "\n",
    "    for row in summary_table_data:\n",
    "        l     = row['Lieferung']\n",
    "        v_id  = row['Fahrzeug']\n",
    "        route = row['geordnete_route']\n",
    "\n",
    "        for step, (u, v) in enumerate(route):\n",
    "            coord_u = node_coords.get(u, (None, None))\n",
    "            coord_v = node_coords.get(v, (None, None))\n",
    "\n",
    "            tunnel_raw = tunnel_category_dict.get((u, v), 'no')\n",
    "            is_tunnel  = tunnel_raw not in ('no', '', None)\n",
    "\n",
    "            writer.writerow({\n",
    "                \"delivery_id\":    l,\n",
    "                \"step\":           step,\n",
    "                \"arc_id\":         arc_id_lookup.get((u, v), -1),\n",
    "                \"u\":              u,\n",
    "                \"v\":              v,\n",
    "                \"length_km\":      round(Dist.get((u, v), 0), 6),\n",
    "                \"risk\":           round(Risk.get(((u, v), Class[l]), 0), 6),\n",
    "                \"variable_cost\":  round(VC.get((v_id, (u, v)), 0), 6),\n",
    "                \"is_tunnel_edge\": is_tunnel,\n",
    "                \"lat_u\":          coord_u[0],\n",
    "                \"lon_u\":          coord_u[1],\n",
    "                \"lat_v\":          coord_v[0],\n",
    "                \"lon_v\":          coord_v[1],\n",
    "            })\n",
    "\n",
    "print(f\"solver_edges_used.csv  => {edges_path}\\n\")\n",
    "\n",
    "print(f\"Alle 3 Dateien exportiert ({timestamp})\")\n"
   ]
