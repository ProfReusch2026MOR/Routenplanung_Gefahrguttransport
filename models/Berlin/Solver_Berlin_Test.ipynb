    "\n",
    "    # Modell\n",
    "    \"variables\":                     len(model.variables()),\n",
    "    \"constraints\":                   len(model.constraints),\n",
    "    \"deliveries\":                    len(L),\n",
    "    \"vehicle_types\":                 len(V),\n",
    "    },\n",
    "    \"timing_s\": {\n",
    "        \"data_preparation\":     round(t1 - t0, 3),\n",
    "        \"network_preparation\":  round(t2 - t1, 3),\n",
    "        \"model_build\":          round(t3 - t2, 3),\n",
    "        \"solver_runtime\":       round(t4 - t3, 3),\n",
    "        \"result_processing\":    round(t5 - t4, 3),\n",
    "        \"core_runtime\":         round(t4 - t2, 3),\n",
    "        \"total_runtime\":        round(t5 - t0, 3),\n",
    "    },\n",
    "    \"results\": {\n",
    "        \"total_fixed_cost_eur\":    round(sum(r['Fixkosten']  for r in summary_table_data), 4),\n",
