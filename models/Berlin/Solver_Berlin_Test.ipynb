    "# ================================\n",
    "# RISIKOSCORE-BERECHNUNG (OPTIMIERT)\n",
    "# ================================\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "df_edges = berlin_graph_accidents['edges']\n",
    "\n",
    "# Kantenliste\n",
    "E = list(zip(df_edges['u'], df_edges['v']))\n",
    "\n",
    "# Gefahrklassen UNIQUE (wichtig!)\n",
    "K = list(all_data['delivery_routes']['danger_class'].unique())\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 1. Gewichtungsparameter\n",
    "# ================================\n",
    "alpha = 0.4   # Population\n",
    "beta  = 0.4   # Accident\n",
    "gamma = 0.2   # Nature\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 2. Dictionaries erstellen (schneller + sauber)\n",
    "# ================================\n",
    "pop_dict = dict(zip(\n",
    "    zip(berlin_graph_population['edges']['u'],\n",
    "        berlin_graph_population['edges']['v']),\n",
    "    berlin_graph_population['edges']['pop_per_meter']\n",
    "))\n",
    "\n",
    "acc_dict = dict(zip(\n",
    "    zip(berlin_graph_accidents['edges']['u'],\n",
    "        berlin_graph_accidents['edges']['v']),\n",
    "    berlin_graph_accidents['edges']['score']\n",
    "))\n",
    "\n",
    "nat_dict = dict(zip(\n",
    "    zip(berlin_graph_nature['edges']['u'],\n",
    "        berlin_graph_nature['edges']['v']),\n",
    "    berlin_graph_nature['edges']['dist_to_nature_m']\n",
    "))\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 3. SAFE NORMALIZATION FUNCTION\n",
    "# ================================\n",
    "def normalize(values_dict, invert=False):\n",
    "    values = np.array(list(values_dict.values()))\n",
    "    vmin, vmax = values.min(), values.max()\n",
    "    \n",
    "    if vmax == vmin:\n",
    "        return {k: 0 for k in values_dict}\n",
    "    \n",
    "    norm = {}\n",
    "    \n",
    "    for k, v in values_dict.items():\n",
    "        val = (v - vmin) / (vmax - vmin + 1e-9)\n",
    "        if invert:\n",
    "            val = 1 - val\n",
    "        norm[k] = val\n",
    "        \n",
    "    return norm\n",
    "\n",
    "\n",
    "# Normalisierte Werte\n",
    "pop_norm = normalize(pop_dict)\n",
    "acc_norm = normalize(acc_dict)\n",
    "nat_norm = normalize(nat_dict, invert=True)  # Nähe = gefährlich\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 4. EDGE RISK (verbessert)\n",
    "# ================================\n",
    "\n",
    "edge_risk = {}\n",
    "\n",
    "for e in E:\n",
    "    \n",
    "    pop = pop_norm.get(e, 0)\n",
    "    acc = acc_norm.get(e, 0)\n",
    "    nat = nat_norm.get(e, 0)\n",
    "    \n",
    "    # 🔥 Verbesserung: Probability × Consequence\n",
    "    consequence = (alpha * pop + gamma * nat)\n",
    "    probability = acc\n",
    "    \n",
    "    risk = probability * consequence\n",
    "    \n",
    "    edge_risk[e] = max(0, min(1, risk))\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 5. Gefahrgutklassen-Faktoren\n",
    "# ================================\n",
    "hazard_class_factors = {\n",
    "    '3': 1.0,\n",
    "    '2 (TOC)': 0.8,\n",
    "    '2': 0.8,\n",
    "    '1.1D': 2.0,\n",
    "    '6': 1.5,\n",
    "    '8': 0.9,\n",
    "    '9': 0.7\n",
    "}\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 6. FINAL RISK DICTIONARY\n",
    "# ================================\n",
    "Risk_calc = {}\n",
    "\n",
    "for e in E:\n",
    "    for k in K:\n",
    "        \n",
    "        factor = hazard_class_factors.get(k, 1.0)\n",
    "        risk_val = edge_risk[e] * factor\n",
    "        \n",
    "        Risk_calc[(e, k)] = max(0, min(1, risk_val))\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 7. DEBUG STATS\n",
    "# ================================\n",
    "risk_values = list(Risk_calc.values())\n",
    "\n",
    "print(\"\\n=== RISIKO STATISTIK ===\")\n",
    "print(f\"Min: {min(risk_values):.4f}\")\n",
    "print(f\"Max: {max(risk_values):.4f}\")\n",
    "print(f\"Mean: {np.mean(risk_values):.4f}\")\n",
    "\n",
    "# Top risk edges\n",
    "top_5 = sorted(Risk_calc.items(), key=lambda x: x[1], reverse=True)[:5]\n",
    "\n",
    "print(\"\\nTOP 5 riskanteste Kanten:\")\n",
    "for ((u,v), k), r in top_5:\n",
    "    print(f\"{u} → {v}, Klasse {k}: {r:.4f}\")"
   ]
