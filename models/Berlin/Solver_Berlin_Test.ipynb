    "        \"time_limit_s\":     300,\n",
    "        \"network_mode\":     \"contracted_graph\",\n",
    "        \"strompreis_eur_kwh\": strompreis,\n",
    "    },\n",
    "    \"weights\": {\n",
    "        \"w1_risk\":   w1,\n",
    "        \"w2_cost\":   w2,\n",
    "        \"alpha_pop\": alpha,\n",
    "        \"beta_acc\":  beta,\n",
    "        \"gamma_nat\": gamma,\n",
    "    },\n",
    "    \"solver_status\": {\n",
    "        \"status\":          pl.LpStatus[model.status],\n",
    "        \"objective_value\": pl.value(model.objective),\n",
    "    },\n",
    "    \"network\": {\n",
