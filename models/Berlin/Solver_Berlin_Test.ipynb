    "# ===============================\n",
    "# MODEL INITIALIZATION\n",
    "# ===============================\n",
    "model = pl.LpProblem(\"Gefahrgut_Routing_VRP_FIXED\", pl.LpMinimize)\n",
    "\n",
    "# ===============================\n",
    "# VARIABLES\n",
    "# ===============================\n",
    "\n",
    "# Routing decision (edges)\n",
    "f = pl.LpVariable.dicts(\n",
    "    \"Fluss\",\n",
    "    valid_le_pairs,\n",
    "    cat='Binary'\n",
    ")\n",
    "\n",
    "# Vehicle assignment\n",
    "y = pl.LpVariable.dicts(\n",
    "    \"Zuweisung\",\n",
    "    [(l, v) for l in L for v in V],\n",
    "    cat='Binary'\n",
    ")\n",
    "\n",
    "# Cost variable\n",
    "CostVar = pl.LpVariable.dicts(\n",
    "    \"CostVar\",\n",
    "    L,\n",
    "    lowBound=0\n",
    ")\n",
    "\n",
    "# ===============================\n",
    "# OBJECTIVE SCALING\n",
    "# ===============================\n",
    "Risk_max = max(Risk.get((e, k), 0) for e in E for k in K)\n",
    "Risk_sum_max = max(1, Risk_max * len(L) * len(E))\n",
    "\n",
    "Cost_max = max(\n",
    "    1,\n",
    "    sum(FC[v] for v in V) +\n",
    "    sum(max(VC[(v, e)] for v in V) for e in E) * len(L)\n",
    ")\n",
    "\n",
    "# ===============================\n",
    "# OBJECTIVE FUNCTION\n",
    "# ===============================\n",
    "risk_term = pl.lpSum(\n",
    "    Risk.get((e, Class[l]), 0) * f[(l, e)]\n",
    "    for l in L\n",
    "    for e in edges_per_l[l]\n",
    ")\n",
    "\n",
    "fixed_cost_term = pl.lpSum(\n",
    "    FC[v] * y[(l, v)]\n",
    "    for l in L for v in V\n",
    ")\n",
    "\n",
    "variable_cost_term = pl.lpSum(CostVar[l] for l in L)\n",
    "\n",
    "model += (\n",
    "    (w1 / Risk_sum_max) * risk_term +\n",
    "    (w2 / Cost_max) * (fixed_cost_term + variable_cost_term)\n",
    ")\n",
    "\n",
    "# ===============================\n",
    "# CONSTRAINTS\n",
    "# ===============================\n",
    "\n",
    "# 1. exactly one vehicle per delivery\n",
    "for l in L:\n",
    "    model += pl.lpSum(y[(l, v)] for v in V) == 1\n",
    "\n",
    "# 2. capacity constraint\n",
    "for l in L:\n",
    "    for v in V:\n",
    "        model += Dem[l] * y[(l, v)] <= Cap[v]\n",
    "\n",
    "# 3. flow allowed only if vehicle is active\n",
    "for l in L:\n",
    "    for e in edges_per_l[l]:\n",
    "        model += f[(l, e)] <= pl.lpSum(y[(l, v)] for v in V)\n",
    "\n",
    "# 4. ADR restrictions\n",
    "for l in L:\n",
    "    for e in edges_per_l[l]:\n",
    "        if Allow.get((e, Class[l]), 1) == 0:\n",
    "            model += f[(l, e)] == 0\n",
    "\n",
    "# ===============================\n",
    "# FLOW CONSERVATION (STABLE VRP)\n",
    "# ===============================\n",
    "for l in L:\n",
    "\n",
    "    nodes = nodes_per_l[l]\n",
    "\n",
    "    for n in nodes:\n",
    "\n",
    "        inflow = pl.lpSum(f[(l, e)] for e in edges_per_l[l] if e[1] == n)\n",
    "        outflow = pl.lpSum(f[(l, e)] for e in edges_per_l[l] if e[0] == n)\n",
    "\n",
    "        if n == O_dep[l]:\n",
    "            model += outflow == 1\n",
    "            model += inflow == 0\n",
    "\n",
    "        elif n == D_dep[l]:\n",
    "            model += inflow == 1\n",
    "            model += outflow == 0\n",
    "\n",
    "        else:\n",
    "            model += inflow == outflow\n",
    "            model += inflow <= 1\n",
    "            model += outflow <= 1\n",
    "\n",
    "# ===============================\n",
    "# SUBTOUR ELIMINATION (STABILIZED MTZ)\n",
    "# ===============================\n",
    "BIG_M = len(nodes_per_l[max(L)])\n",
    "\n",
    "u = pl.LpVariable.dicts(\n",
    "    \"order\",\n",
    "    [(l, n) for l in L for n in nodes_per_l[l]],\n",
    "    lowBound=0,\n",
    "    cat='Continuous'\n",
    ")\n",
    "\n",
    "for l in L:\n",
    "\n",
    "    M = len(nodes_per_l[l])\n",
    "\n",
    "    # Depot fix\n",
    "    model += u[(l, O_dep[l])] == 0\n",
    "\n",
    "    for (i, j) in edges_per_l[l]:\n",
    "\n",
    "        if i in nodes_per_l[l] and j in nodes_per_l[l]:\n",
    "\n",
    "            model += (\n",
    "                u[(l, i)] + 1\n",
    "                <= u[(l, j)] + M * (1 - f[(l, (i, j))])\n",
    "            )\n",
    "\n",
    "# ===============================\n",
    "# COST LINKING (OPTIMIZED)\n",
    "# ===============================\n",
    "M_cost = Cost_max\n",
    "\n",
    "for l in L:\n",
    "    for v in V:\n",
    "\n",
    "        route_cost = pl.lpSum(\n",
    "            VC[(v, e)] * f[(l, e)]\n",
    "            for e in edges_per_l[l]\n",
    "        )\n",
    "\n",
    "        model += CostVar[l] >= route_cost - M_cost * (1 - y[(l, v)])\n",
    "\n",
    "# ===============================\n",
    "# DEBUG OUTPUT\n",
    "# ===============================\n",
    "print(\"------------------------------------------------\")\n",
    "print(f\"Variablen: {len(model.variables())}\")\n",
    "print(f\"Constraints: {len(model.constraints)}\")\n",
    "print(\"------------------------------------------------\")"
   ]
