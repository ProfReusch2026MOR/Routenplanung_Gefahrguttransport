    "# ================================\n",
    "# SCHNELLER NODE-MAPPER (OPTIMIERT)\n",
    "# ================================\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "# Knotendaten vorbereiten\n",
    "df_nodes = berlin_graph_accidents[\"nodes\"]\n",
    "\n",
    "node_ids = df_nodes[\"node\"].values\n",
    "node_lats = df_nodes[\"lat\"].values\n",
    "node_lons = df_nodes[\"lon\"].values\n",
    "\n",
    "\n",
    "# ================================\n",
    "# Vektorisiertes Haversine\n",
    "# ================================\n",
    "def haversine_vectorized(lat1, lon1, lat2, lon2):\n",
    "    R = 6371000  # Meter\n",
    "    \n",
    "    lat1 = np.radians(lat1)\n",
    "    lon1 = np.radians(lon1)\n",
    "    lat2 = np.radians(lat2)\n",
    "    lon2 = np.radians(lon2)\n",
    "\n",
    "    dlat = lat2 - lat1\n",
    "    dlon = lon2 - lon1\n",
    "\n",
    "    a = np.sin(dlat / 2)**2 + np.cos(lat1) * np.cos(lat2) * np.sin(dlon / 2)**2\n",
    "    c = 2 * np.arctan2(np.sqrt(a), np.sqrt(1 - a))\n",
    "\n",
    "    return R * c\n",
    "\n",
    "\n",
    "# ================================\n",
    "# DEPOT → KNOTEN MAPPING\n",
    "# ================================\n",
    "distances = haversine_vectorized(\n",
    "    depot_lat,\n",
    "    depot_lon,\n",
    "    node_lats,\n",
    "    node_lons\n",
    ")\n",
    "\n",
    "min_idx = np.argmin(distances)\n",
    "\n",
    "depot_node_result = int(node_ids[min_idx])\n",
    "\n",
    "print(f\"Depot gemappt auf Knoten: {depot_node_result} ({round(distances[min_idx],2)} m)\")\n",
    "\n",
    "\n",
    "# ================================\n",
    "# KUNDEN → KNOTEN MAPPING\n",
    "# ================================\n",
    "customer_to_node = {}\n",
    "\n",
    "df_customers = all_data['customer_locations']\n",
    "\n",
    "for _, customer in df_customers.iterrows():\n",
    "\n",
    "    distances = haversine_vectorized(\n",
    "        customer[\"Breitengrad\"],\n",
    "        customer[\"Längengrad\"],\n",
    "        node_lats,\n",
    "        node_lons\n",
    "    )\n",
    "\n",
    "    min_idx = np.argmin(distances)\n",
    "\n",
    "    customer_to_node[customer[\"Nr\"]] = {\n",
    "        \"customer_name\": customer[\"Ort\"],\n",
    "        \"nearest_node\": int(node_ids[min_idx]),\n",
    "        \"distance_m\": round(float(distances[min_idx]), 2)\n",
    "    }\n",
    "\n",
    "\n",
    "# ================================\n",
    "# DEBUG OUTPUT\n",
    "# ================================\n",
    "print(\"\\n=== Kunden-Mapping ===\")\n",
    "\n",
    "for cid, info in customer_to_node.items():\n",
    "    print(f\"Kunde {cid}: {info['customer_name']}\")\n",
    "    print(f\"→ Knoten: {info['nearest_node']}\")\n",
    "    print(f\"→ Distanz: {info['distance_m']} m\")\n",
    "    print(\"-\" * 40)\n",
    "\n",
    "\n",
